{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }],
  "title": "netmon — Network Traffic Monitor",
  "uid": "netmon-v2",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1, "gridPos": {"h":4,"w":4,"x":0,"y":0}, "type": "stat", "title": "Total Connections",
      "targets": [{"expr": "netmon_connections_total", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background","graphMode":"area"},
      "fieldConfig": {"defaults":{"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":0},{"color":"yellow","value":500},{"color":"red","value":1000}]}}}
    },
    {
      "id": 2, "gridPos": {"h":4,"w":4,"x":4,"y":0}, "type": "stat", "title": "Established",
      "targets": [{"expr": "netmon_connections_established", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
      "fieldConfig": {"defaults":{"color":{"fixedColor":"green","mode":"fixed"}}}
    },
    {
      "id": 3, "gridPos": {"h":4,"w":4,"x":8,"y":0}, "type": "stat", "title": "Listen",
      "targets": [{"expr": "netmon_connections_listen", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
      "fieldConfig": {"defaults":{"color":{"fixedColor":"blue","mode":"fixed"}}}
    },
    {
      "id": 4, "gridPos": {"h":4,"w":4,"x":12,"y":0}, "type": "stat", "title": "Time Wait",
      "targets": [{"expr": "netmon_connections_time_wait", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
      "fieldConfig": {"defaults":{"color":{"fixedColor":"yellow","mode":"fixed"}}}
    },
    {
      "id": 5, "gridPos": {"h":4,"w":4,"x":16,"y":0}, "type": "stat", "title": "RX Rate",
      "targets": [{"expr": "netmon_rx_bytes_per_second", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
      "fieldConfig": {"defaults":{"unit":"Bps","color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":0},{"color":"yellow","value":1048576},{"color":"red","value":10485760}]}}}
    },
    {
      "id": 6, "gridPos": {"h":4,"w":4,"x":20,"y":0}, "type": "stat", "title": "TX Rate",
      "targets": [{"expr": "netmon_tx_bytes_per_second", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background"},
      "fieldConfig": {"defaults":{"unit":"Bps","color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":0},{"color":"yellow","value":1048576},{"color":"red","value":10485760}]}}}
    },
    {
      "id": 10, "gridPos": {"h":8,"w":12,"x":0,"y":4}, "type": "timeseries", "title": "Connection States Over Time",
      "targets": [
        {"expr": "netmon_connections_established", "legendFormat": "ESTABLISHED", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}},
        {"expr": "netmon_connections_listen",      "legendFormat": "LISTEN",      "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}},
        {"expr": "netmon_connections_time_wait",   "legendFormat": "TIME_WAIT",   "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}},
        {"expr": "netmon_connections_close_wait",  "legendFormat": "CLOSE_WAIT",  "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}},
        {"expr": "netmon_connections_udp",         "legendFormat": "UDP",         "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}
      ],
      "fieldConfig": {"defaults":{"unit":"short"}}
    },
    {
      "id": 11, "gridPos": {"h":8,"w":12,"x":12,"y":4}, "type": "timeseries", "title": "Aggregate Throughput",
      "targets": [
        {"expr": "netmon_rx_bytes_per_second", "legendFormat": "RX bytes/s", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}},
        {"expr": "netmon_tx_bytes_per_second", "legendFormat": "TX bytes/s", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}
      ],
      "fieldConfig": {"defaults":{"unit":"Bps"}}
    },
    {
      "id": 20, "gridPos": {"h":8,"w":24,"x":0,"y":12}, "type": "timeseries", "title": "Per-Interface RX Rate",
      "targets": [{"expr": "netmon_interface_rx_bytes_per_second", "legendFormat": "{{interface}}", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults":{"unit":"Bps"}}
    },
    {
      "id": 21, "gridPos": {"h":8,"w":24,"x":0,"y":20}, "type": "timeseries", "title": "Per-Interface TX Rate",
      "targets": [{"expr": "netmon_interface_tx_bytes_per_second", "legendFormat": "{{interface}}", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults":{"unit":"Bps"}}
    },
    {
      "id": 30, "gridPos": {"h":8,"w":12,"x":0,"y":28}, "type": "timeseries", "title": "Top Processes — RX/s",
      "targets": [{"expr": "topk(10, netmon_process_rx_bytes_per_second)", "legendFormat": "{{process}} ({{pid}})", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults":{"unit":"Bps"}}
    },
    {
      "id": 31, "gridPos": {"h":8,"w":12,"x":12,"y":28}, "type": "timeseries", "title": "Top Processes — TX/s",
      "targets": [{"expr": "topk(10, netmon_process_tx_bytes_per_second)", "legendFormat": "{{process}} ({{pid}})", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults":{"unit":"Bps"}}
    },
    {
      "id": 32, "gridPos": {"h":8,"w":12,"x":0,"y":36}, "type": "timeseries", "title": "Process CPU %",
      "targets": [{"expr": "topk(10, netmon_process_cpu_percent)", "legendFormat": "{{process}} ({{pid}})", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults":{"unit":"percent"}}
    },
    {
      "id": 33, "gridPos": {"h":8,"w":12,"x":12,"y":36}, "type": "timeseries", "title": "Process Memory",
      "targets": [{"expr": "topk(10, netmon_process_memory_bytes)", "legendFormat": "{{process}} ({{pid}})", "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "fieldConfig": {"defaults":{"unit":"bytes"}}
    },
    {
      "id": 40, "gridPos": {"h":6,"w":12,"x":0,"y":44}, "type": "table", "title": "Connection State Breakdown",
      "targets": [{"expr": "netmon_connection_state_count", "legendFormat": "{{state}}", "instant": true, "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}],
      "transformations": [{"id":"labelsToFields","options":{}}]
    },
    {
      "id": 41, "gridPos": {"h":6,"w":12,"x":12,"y":44}, "type": "piechart", "title": "Connections by Protocol",
      "targets": [{"expr": "netmon_connection_protocol_count", "legendFormat": "{{protocol}}", "instant": true, "datasource": {"type":"prometheus","uid":"${DS_PROMETHEUS}"}}]
    }
  ]
}
